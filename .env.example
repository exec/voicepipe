# --- discord ---
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# --- Ollama Cloud (OpenAI-compatible /v1 endpoint) ---
OLLAMA_API_KEY=
OLLAMA_BASE_URL=https://ollama.com/v1
OLLAMA_MODEL=dec-bot

# --- local Ollama alternative (uncomment to use the locally-registered dec-bot) ---
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_API_KEY=ollama-local

# --- bot behavior ---
# always | mention | random
RESPONSE_MODE=always
HISTORY_TURNS=6
RANDOM_REPLY_P=0.5

# random seconds of fake typing pace between generation finishing and message send
REPLY_DELAY_RANGE=1.0,3.0

# generation knobs (match Modelfile defaults)
GEN_TEMPERATURE=0.85
GEN_TOP_P=0.9
GEN_MAX_TOKENS=400
