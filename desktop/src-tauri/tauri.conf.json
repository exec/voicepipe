{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "voicepipe",
  "version": "0.1.0",
  "identifier": "dev.voicepipe.desktop",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../../pipeline/webui"
  },
  "app": {
    "windows": [],
    "withGlobalTauri": true,
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"],
    "category": "DeveloperTool",
